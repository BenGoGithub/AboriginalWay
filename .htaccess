# ============================================================
# Aboriginal Way - Configuration Apache
# ============================================================

# --- Redirection www → non-www ---
RewriteEngine On
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# --- Redirection HTTP → HTTPS ---
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- Compression gzip (réduit la taille des fichiers transférés) ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE text/xml application/xml text/plain
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# --- Cache navigateur / CDN (contrôle la durée de mise en cache) ---
<IfModule mod_expires.c>
    ExpiresActive On

    # Images : 1 an (rarement modifiées)
    ExpiresByType image/jpeg   "access plus 1 year"
    ExpiresByType image/gif    "access plus 1 year"
    ExpiresByType image/png    "access plus 1 year"
    ExpiresByType image/webp   "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon  "access plus 1 year"

    # CSS et JavaScript : 1 mois
    ExpiresByType text/css                "access plus 1 month"
    ExpiresByType application/javascript  "access plus 1 month"
    ExpiresByType text/javascript         "access plus 1 month"

    # HTML : 1 heure (pages pouvant être mises à jour)
    ExpiresByType text/html "access plus 1 hour"

    # Polices
    ExpiresByType font/woff2      "access plus 1 year"
    ExpiresByType font/woff       "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
</IfModule>

# --- En-têtes Cache-Control explicites (lus par les CDN) ---
<IfModule mod_headers.c>
    # Images et polices : immutables pendant 1 an
    <FilesMatch "\.(jpg|jpeg|gif|png|webp|svg|ico|woff|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # CSS et JS : 1 mois, revalidation possible
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>

    # HTML : 1 heure, revalidation
    <FilesMatch "\.html$">
        Header set Cache-Control "public, max-age=3600, must-revalidate"
    </FilesMatch>

    # En-têtes de sécurité de base
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# --- Keep-Alive (réutilisation des connexions TCP) ---
<IfModule mod_headers.c>
    Header set Connection keep-alive
</IfModule>

# --- ETags (validation du cache côté navigateur) ---
FileETag MTime Size

# --- Page d'erreur 404 personnalisée ---
ErrorDocument 404 /index.html

# --- Redirections 301 : pages desktop → URLs propres (SEO + GTM) ---
RewriteEngine On
RewriteBase /

RewriteCond %{HTTP:X-Fetch-Content} !1
RewriteRule ^site/ref/documents/home\.html$             /                    [R=301,L]
RewriteCond %{HTTP:X-Fetch-Content} !1
RewriteRule ^site/ref/documents/exposition\.html$       /exposition          [R=301,L]
RewriteCond %{HTTP:X-Fetch-Content} !1
RewriteRule ^site/ref/documents/artistes\.html$         /artistes            [R=301,L]
RewriteCond %{HTTP:X-Fetch-Content} !1
RewriteRule ^site/ref/documents/photo\.html$            /photos              [R=301,L]
RewriteCond %{HTTP:X-Fetch-Content} !1
RewriteRule ^site/ref/documents/animation-peinture\.html$ /animation-peinture [R=301,L]
RewriteCond %{HTTP:X-Fetch-Content} !1
RewriteRule ^site/ref/documents/didgeridoo\.html$       /didgeridoo          [R=301,L]
RewriteCond %{HTTP:X-Fetch-Content} !1
RewriteRule ^site/ref/documents/activites\.html$        /activites           [R=301,L]
RewriteCond %{HTTP:X-Fetch-Content} !1
RewriteRule ^site/ref/documents/presentation\.html$     /presentation        [R=301,L]
RewriteCond %{HTTP:X-Fetch-Content} !1
RewriteRule ^site/ref/documents/membres\.html$          /membres             [R=301,L]
RewriteCond %{HTTP:X-Fetch-Content} !1
RewriteRule ^site/ref/documents/partenaires\.html$      /partenaires         [R=301,L]
RewriteCond %{HTTP:X-Fetch-Content} !1
RewriteRule ^site/ref/documents/contact\.html$          /contact             [R=301,L]

# --- SPA Router : réécriture des URLs propres vers index.html ---

# Redirection index.html → / (évite le doublon de page d'accueil)
RewriteRule ^index\.html$ / [R=301,L]

# Ne pas réécrire les fichiers et dossiers existants
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Tout le reste → index.html (le router JS prend le relai)
RewriteRule . /index.html [L]
